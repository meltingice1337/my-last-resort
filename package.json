{
  "name": "emergency-vault",
  "version": "2.0.0",
  "description": "Emergency Vault — recover encrypted secrets using Shamir's Secret Sharing",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy-pages": "vite build && gh-pages -d dist && rm -rf dist",
    "cli:build": "pnpm --filter emergency-vault-cli build",
    "vault": "pnpm cli:build && node cli/dist/index.js",
    "vault:cleanup": "find vault-workspace -type f -exec shred -vfzu {} + 2>/dev/null; rm -rf vault-workspace && echo 'vault-workspace/ shredded and destroyed.'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.18.0",
  "dependencies": {
    "jsqr": "^1.4.0",
    "lucide-react": "^0.546.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "secrets.js-grempe": "^2.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "gh-pages": "^6.3.0",
    "prettier": "^3.6.2",
    "prettier-eslint": "^16.4.2",
    "tailwindcss": "^4.1.14",
    "terser": "^5.44.0",
    "vite": "^7.1.10"
  }
}
