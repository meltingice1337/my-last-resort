  "license": "ISC",
  "packageManager": "pnpm@10.18.0",
  "dependencies": {
    "jsqr": "^1.4.0",
    "lucide-react": "^0.546.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "secrets.js-grempe": "^2.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitejs/plugin-react": "^5.1.4",
    "gh-pages": "^6.3.0",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "tailwindcss": "^4.2.1",
    "terser": "^5.46.0",
    "vite": "^7.3.1"
  }
