{
  "name": "emergency-vault",
  "version": "2.0.0",
  "description": "Emergency Vault — recover encrypted secrets using Shamir's Secret Sharing",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy-pages": "vite build && gh-pages -d dist && rm -rf dist",
    "cli:build": "pnpm --filter emergency-vault-cli build",
    "vault": "pnpm cli:build && node cli/dist/index.js",
    "vault:compile": "pnpm cli:build && bun build cli/dist/index.js --compile --outfile vault-cli --target=bun-linux-x64"
  },
  "keywords": [],
